# ─────────────────────────────────────────────────────────
# AudioGuardMP_2026 — Environment Variables
# Copy this file to .env and fill in actual values.
# The .env file is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────

# ── IEMOCAP Dataset (optional) ─────────────────────────
# Path to the root of your local IEMOCAP dataset folder.
# Required if you want to include IEMOCAP in SER training.
# Leave blank if you only want to use RAVDESS + TESS.
# Example: IEMOCAP_PATH=C:/Datasets/IEMOCAP_full_release
IEMOCAP_PATH=

# ── Random Seed ─────────────────────────────────────────
SEED=42

# ── HuggingFace Hub (optional) ──────────────────────────
# Set this if you want to push models to HuggingFace Hub
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
